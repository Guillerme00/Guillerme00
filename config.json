{
  "theme": {

    "gradient": {
      
      "_colors_comment": "Two-stop gradient used in header, divider, and footer backgrounds.",
      "colors": ["#1e1b4b", "#4c1d95"],

      "_fade_comment": "Fade transparency on left/right edges.",
      "fade": {
        "left": true,
        "right": true
      }
    },

    "_accent_comment": "Accent color used for typing text, cursor, and stats values.",
    "accent": "#a78bfa"

  },

  "header": {

    "_generates": "assets/header.svg",
    "_comment": null,

    "name": null,
    "bio": null
  },

  "typing": {

    "_generates": "assets/typing.svg",
    "_comment": null,

    "lines": [
      "HTML CSS JS",
      "TS React",
      "Python Django",
      "Git Docker"
    ]
  },

  "labels": [
    { 
      "_generates": "assets/labels/{id}.svg" 
    },

    { "id": "lang",  "text": "Languages" },
    { "id": "fw",    "text": "Frameworks & Runtimes" },
    { "id": "tools", "text": "Tools & Environment" }
  ],

  "badges": [
    {
      "_generates": "assets/badges/{id}.svg"
    },

    { "id": "html5",         "text": "HTML5",        "color": "#cc4420" },
    { "id": "css3",          "text": "CSS3",         "color": "#1262a0" },
    { "id": "javascript",    "text": "JAVASCRIPT",   "color": "#e0c910" },
    { "id": "nodejs",        "text": "NODE.JS",      "color": "#2b802b" },
    { "id": "python",        "text": "PYTHON",       "color": "#58a0e4" },
    { "id": "django",        "text": "DJANGO",       "color": "#67d569" },
    { "id": "git",           "text": "GIT",          "color": "#d94229" },
    { "id": "github",        "text": "GITHUB",       "color": "#1c2025" },
    { "id": "vscode",        "text": "VS CODE",      "color": "#0069b3" },
    { "id": "claude-code",   "text": "CLAUDE CODE",  "color": "#bf6a05" }
  ],

  "divider": {

    "_generates": "assets/divider.svg",
    "_comment": "Thin animated ribbon divider with wavy top and bottom edges — static, no config needed"

  },

  "stats": {

    "_generates": "assets/stats.svg",
    "_comment": "GitHub Stats Card — fetched automatically via GitHub GraphQL API",

    "show": {
      "commits":   true,
      "prs":       true,
      "issues":    false,
      "stars":     true,
      "repos":     true,
      "followers": true
    }

  },

  "langs": {

    "_generates": "assets/langs.svg",
    "_comment": "Top Languages Chart — fetched automatically via GitHub GraphQL API"

  },

  "footer": {

    "_generates": "assets/footer.svg",
    "_comment": "Animated wave footer — static, no config needed"

  }
}
